KANBAN_API_IMAGE=ghcr.io/owner/repo-api:latest
KANBAN_MCP_IMAGE=ghcr.io/owner/repo-mcp:latest
KANBAN_API_HTTP_PORT=8080

Auth__Enabled=true
Auth__Authority=https://identity.trefry.net/realms/YOUR_REALM
Auth__ClientId=kanban-board
Auth__ClientSecret=replace-with-keycloak-client-secret
Auth__RequireHttpsMetadata=true

PersonalAccessTokens__Enabled=true
PersonalAccessTokens__EncryptionKey=replace-with-32-byte-base64-or-64-hex-key
PersonalAccessTokens__TokenPrefix=kbp
